# Replace YOUR_IP with your computer's IP address from ipconfig
# Example: NEXT_PUBLIC_API_URL=http://192.168.1.5:5000/api
NEXT_PUBLIC_API_URL=https://jos-marketplace-backend.onrender.com/api

# Database (add your PostgreSQL URL from Vercel/Neon/Supabase)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Email (Gmail App Password - NOT your regular password)
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-gmail-app-password"

# JWT
JWT_SECRET="your-secret-key-here"
